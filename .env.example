# =============================================================================
# Ventas-Stock - Variables de Entorno
# Copiar a .env y completar con valores reales
# =============================================================================

# -----------------------------------------------------------------------------
# Empresa
# -----------------------------------------------------------------------------
VITE_EMPRESA_RAZON_SOCIAL=Mi Empresa SRL
VITE_EMPRESA_CUIT=20123456789
VITE_EMPRESA_DOMICILIO=Av. Corrientes 1234, CABA
VITE_EMPRESA_CONDICION_IVA=Monotributo
VITE_EMPRESA_PUNTO_VENTA=1

# -----------------------------------------------------------------------------
# AFIP / ARCA
# -----------------------------------------------------------------------------
# Ambiente: 'homologacion' (testing) o 'produccion'
AFIP_AMBIENTE=homologacion

# CUIT del emisor (sin guiones)
AFIP_CUIT=20123456789

# Rutas a certificado digital emitido por AFIP
# Ver README.md - sección "AFIP Checklist" para obtenerlos
AFIP_CERT_PATH=./certs/cert.pem
AFIP_KEY_PATH=./certs/key.pem

# Passphrase de la clave privada (dejar vacío si no tiene)
AFIP_PASSPHRASE=

# Tipo de comprobante por defecto:
# 11 = Factura C, 1 = Factura A, 6 = Factura B
AFIP_TIPO_COMPROBANTE=11

# -----------------------------------------------------------------------------
# Base de datos SQLite
# -----------------------------------------------------------------------------
DB_PATH=./data/ventas.db

# -----------------------------------------------------------------------------
# Backup
# -----------------------------------------------------------------------------
BACKUP_DIR=./backups

# Retención de backups automáticos (días)
BACKUP_RETENTION_DAYS=30
