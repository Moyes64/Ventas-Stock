# Dependencies
node_modules/
.pnp
.pnp.js
package-lock.json

# Build outputs
dist/
dist-electron/
release/
out/

# SQLite databases
*.db
*.db-journal
*.db-shm
*.db-wal
data/

# Backups
backups/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# AFIP certificates (never commit real certs)
certs/*.pem
certs/*.key
certs/*.p12
certs/*.pfx
!certs/.gitkeep

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V500
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Editor directories
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# TypeScript
*.tsbuildinfo

# Testing
coverage/

# Temporary files
*.tmp
*.temp

# electron-builder
app-builds/

# Electron cache (auto-generated at runtime)
.electron/
electron-cache/

# pnpm store cache (local)
.pnpm-store/

# Windows: files auto-generated by the OS or file explorer
$RECYCLE.BIN/
System Volume Information

# Runtime / app user-data (Electron stores session data here during dev)
userdata/
