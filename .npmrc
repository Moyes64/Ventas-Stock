# Hoist native-module support packages so electron-builder can find them
# when packaging with pnpm's virtual store layout.
#
# better-sqlite3 requires 'bindings' at runtime to locate the compiled
# .node file.  bindings in turn requires 'file-uri-to-path'.  Without
# hoisting, both packages live only in the pnpm virtual store (.pnpm/)
# and are invisible to electron-builder's dependency scanner.
public-hoist-pattern[]=bindings
public-hoist-pattern[]=file-uri-to-path
