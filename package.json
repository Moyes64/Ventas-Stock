{
  "name": "ventas-stock",
  "version": "1.0.0",
  "description": "Desktop application for Sales and Stock management with Argentine AFIP electronic invoicing",
  "main": "dist/main/index.js",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "clean": "node scripts/clean.cjs",
    "dev:clean": "pnpm clean && electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "lint": "eslint . --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"electron/**/*.ts\" \"database/**/*.ts\" \"scripts/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"electron/**/*.ts\" \"database/**/*.ts\"",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "db:migrate:node": "tsx scripts/migrate.ts",
    "db:seed:node": "tsx scripts/seed.ts",
    "db:migrate:electron": "electron scripts/electron-migrate.cjs",
    "db:seed:electron": "electron scripts/electron-seed.cjs",
    "typecheck": "tsc --noEmit",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "package": "node scripts/package.cjs",
    "package:win": "node scripts/package.cjs --win",
    "package-win": "node scripts/package.cjs --win",
    "check:conflicts": "node scripts/check-merge-markers.js",
    "postinstall": "node scripts/postinstall.cjs"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "better-sqlite3": "12.9.0",
    "date-fns": "^3.3.1",
    "dotenv": "^16.4.7",
    "node-forge": "^1.4.0",
    "qrcode": "^1.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.1",
    "thermal-printer-encoder": "^2.0.0-alpha.15",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^1.0.2",
    "@electron-toolkit/eslint-config-ts": "^2.0.0",
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/better-sqlite3": "7.6.13",
    "@types/node": "^20.11.16",
    "@types/node-forge": "^1.3.10",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^39.8.1",
    "@electron/rebuild": "^3.7.1",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.5",
    "tsx": "^4.7.1",
    "typescript": "5.5.4",
    "vite": "^5.1.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.1",
  "build": {
    "appId": "com.ventasstock.app",
    "productName": "Ventas-Stock",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "database/migrations",
        "to": "database/migrations"
      }
    ],
    "npmRebuild": false,
    "asarUnpack": [
      "**/*.node"
    ],
    "linux": {
      "target": "AppImage"
    },
    "win": {
      "target": "nsis",
      "sign": "./scripts/win-sign.cjs"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
